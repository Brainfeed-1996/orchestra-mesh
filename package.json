{
  "name": "orchestra-mesh",
  "private": true,
  "version": "1.0.0",
  "description": "Enterprise-grade durable distributed workflow engine",
  "author": "Orchestra Mesh Team",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Brainfeed-1996/orchestra-mesh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Brainfeed-1996/orchestra-mesh.git"
  },
  "keywords": [
    "workflow",
    "orchestration",
    "event-sourcing",
    "durable-execution",
    "automation",
    "approval"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:watch": "tsc --build --watch",
    "clean": "rm -rf dist coverage",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,json,md,yml,yaml}\"",
    "typecheck": "tsc --noEmit",
    "dev:control-plane": "node apps/control-plane/dist/index.js",
    "dev:ui": "node apps/web-ui/dist/server.js"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^27.8.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "uuid": "^9.0.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}